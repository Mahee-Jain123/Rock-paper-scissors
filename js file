let Rounds = 0;
let currentRound = 0;
let player_score = 0;
let computer_score = 0;
let gameOver = true; 
function get_computer_choice() { 
    let x = Math.random();
    if (x < 1/3) {
        return "rock";
    } else if (x < 2/3) {
        return "paper";
    } else {
        return "scissors";
    }
}

function startGame() {
    let input = Number(document.getElementById("rounds").value);

    if (!input || input <= 0) {
        document.getElementById("result").textContent = "Please enter a valid number of rounds.";
        return;
    }

    Rounds = input;
    currentRound = 0;
    player_score = 0;
    computer_score = 0;
    gameOver = false;

    document.getElementById("result").textContent = `Game started! Play ${Rounds} round(s).`;
    document.getElementById("score").textContent = `Player: 0 | Computer: 0`;
}

function playRound(playerChoice) {
    if (gameOver) {
        document.getElementById("result").textContent = "Please submit number of rounds first.";
        return;
    }

    let computerChoice = get_computer_choice();
    let roundText = "";

    if (playerChoice === computerChoice) {
        roundText = `Tie! Both chose ${playerChoice}.`;
    } else if (
        (playerChoice === 'scissors' && computerChoice === 'rock') ||
        (playerChoice === 'paper' && computerChoice === 'scissors') === false &&
        (playerChoice === 'rock' && computerChoice === 'paper') === false
    ) {
        
    }

   
    const beats = {
        rock: 'scissors',
        paper: 'rock',
        scissors: 'paper'
    };

    if (playerChoice === computerChoice) {
        roundText = `Tie! Both chose ${playerChoice}.`;
    } else if (beats[playerChoice] === computerChoice) {
        player_score++;
        roundText = `You chose ${playerChoice}, computer chose ${computerChoice}. You win this round!`;
    } else {
        computer_score++;
        roundText = `You chose ${playerChoice}, computer chose ${computerChoice}. Computer wins this round!`;
    }

    currentRound++;
    document.getElementById("result").textContent = roundText;
    document.getElementById("score").textContent =
        `Round ${currentRound}/${Rounds} — Player: ${player_score} | Computer: ${computer_score}`;

    if (currentRound >= Rounds) {
        gameOver = true;
        let finalText = "";
        if (player_score > computer_score) {
            finalText = "🎉 Player wins the game!";
        } else if (computer_score > player_score) {
            finalText = "💻 Computer wins the game!";
        } else {
            finalText = "It's an overall tie!";
        }
        document.getElementById("result").textContent += ` — ${finalText}`;
    }
}
